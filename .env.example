# Neon / Postgres — SQLAlchemy + psycopg2 (replace USER, PASSWORD, HOST):
# DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST/neondb?sslmode=require
DATABASE_URL=

SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Browsers that may call the API (include the URL where you open the UI)
CORS_ORIGINS=http://127.0.0.1:8000,http://localhost:8000,http://localhost:5173,http://127.0.0.1:5173

UPLOAD_DIR=./uploads

# Optional: OpenRouter — LLM for /api/chat (https://openrouter.ai/keys)
# Free models can return HTTP 429 when upstream is busy; the app retries and rotates fallbacks.
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=google/gemma-2-9b-it:free
# OPENROUTER_MODEL_FALLBACKS=meta-llama/llama-3.2-3b-instruct:free,nvidia/nemotron-nano-9b-v2:free,openrouter/free
# OPENROUTER_429_MAX_ATTEMPTS=3
# OPENROUTER_429_RETRY_DELAY_SECONDS=3
# OPENROUTER_REFERER=http://127.0.0.1:8000
